# ─── Required ─────────────────────────────────────────────────────────────────

# Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=your_random_secret_here

# Admin credentials — these are the ONLY way to create an admin account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password

# Secret to protect manual cron trigger — generate with: openssl rand -hex 16
CRON_SECRET=your_cron_secret_here

# ─── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-set by Vercel when you add Blob storage. For local dev:
# Get from: https://vercel.com/dashboard → Storage → your blob store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Optional ─────────────────────────────────────────────────────────────────
# Only needed for local Docker dev if you want to restrict CORS
# FRONTEND_URL=https://your-domain.vercel.app
